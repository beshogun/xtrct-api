DATABASE_URL=postgresql://user:pass@host/scraper
FLARESOLVERR_URL=http://localhost:8191
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_PROXY_CREDITS=price_...
ADMIN_KEY=your-secret-admin-key
PUBLIC_URL=https://api.xtrct.io
PORT=3000
BROWSER_POOL_SIZE=3
WORKER_CONCURRENCY=4

# S3-compatible storage (Cloudflare R2, MinIO, AWS S3, etc.)
# Leave unset to fall back to base64 in JSON responses
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=scraper-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=   # optional: public CDN base URL (e.g. https://assets.example.com)

# Proxy rotation (comma-separated or newline-separated URLs)
# Leave unset to disable proxying
PROXY_LIST=http://user:pass@host1:port,http://user:pass@host2:port
PROXY_LIST_FILE=/etc/scraper/proxies.txt

# Webshare datacenter proxy integration (fetches list via API)
# Sign up at https://webshare.io — API key from dashboard
WEBSHARE_API_KEY=

# Webshare residential proxies (rotating endpoint — no list to fetch)
WEBSHARE_RESIDENTIAL_USER=
WEBSHARE_RESIDENTIAL_PASS=

# Slipstream Engine — smart escalation backend (cheaper Step 0 before Playwright/FlareSolverr)
# Get from https://slipstream-engine.fly.dev — leave unset to disable
SLIPSTREAM_URL=https://slipstream-engine.fly.dev
SLIPSTREAM_API_KEY=
